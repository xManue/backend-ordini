<Window x:Class="Applicazione_OrdiniInterna.Dialogs.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Piatto" Height="340" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource PageBg}">
    <StackPanel Margin="24">
        <TextBlock Text="Nome" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

        <TextBlock Text="Descrizione" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
        <TextBox x:Name="DescBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Prezzo (€)" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="PriceBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Categoria" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="CategoryBox" Style="{StaticResource ModernTextBox}"/>
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Annulla" Style="{StaticResource SecondaryButton}" Click="CancelClick" Margin="0,0,8,0"/>
            <Button Content="Salva" Style="{StaticResource BrandButton}" Click="SaveClick"/>
        </StackPanel>
    </StackPanel>
</Window>