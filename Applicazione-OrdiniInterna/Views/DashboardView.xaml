<UserControl x:Class="Applicazione_OrdiniInterna.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBg}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="24,16" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Piatti del Menu" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Gestisci i piatti del tuo ristorante" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="➕ Aggiungi Piatto" Click="AddProductClick" Style="{StaticResource BrandButton}" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Filters -->
        <Border DockPanel.Dock="Top" Padding="24,12" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SearchBox" Style="{StaticResource ModernTextBox}" Width="250" TextChanged="SearchChanged" />
                <ComboBox x:Name="CategoryFilter" Width="180" Margin="12,0,0,0" SelectionChanged="CategoryChanged" FontSize="13" Padding="8,6"/>
            </StackPanel>
        </Border>

        <!-- Product List -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProductList" Margin="24,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>