<UserControl x:Class="Applicazione_OrdiniInterna.Views.CustomerDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1E293B" Padding="40,20">
            <DockPanel>
                <TextBlock Text="🍕 Bella Cucina" FontSize="32" FontWeight="Bold" Foreground="White" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Clock}" FontSize="28" FontWeight="SemiBold" Foreground="#94A3B8" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Two-Column Display -->
        <Grid Margin="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: In Preparazione -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Background="#F59E0B" CornerRadius="16,16,0,0" Padding="24,16">
                    <TextBlock Text="🔥 IN PREPARAZIONE" FontSize="28" FontWeight="ExtraBold" Foreground="Black" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="#1E293B" CornerRadius="0,0,16,16" Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding PreparingOrders}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#334155" CornerRadius="16" Margin="8" Padding="20,16" MinWidth="140">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock FontSize="48" FontWeight="ExtraBold" Foreground="#FBBF24" HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="#{0}">
                                                        <Binding Path="OrderId"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding TableLabel}" FontSize="16" Foreground="#94A3B8" HorizontalAlignment="Center" Visibility="{Binding TableLabel, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <!-- RIGHT: Pronti -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top" Background="#22C55E" CornerRadius="16,16,0,0" Padding="24,16">
                    <TextBlock Text="✅ PRONTI" FontSize="28" FontWeight="ExtraBold" Foreground="Black" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="#1E293B" CornerRadius="0,0,16,16" Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding ReadyOrders}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#334155" CornerRadius="16" Margin="8" Padding="20,16" MinWidth="140">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock FontSize="48" FontWeight="ExtraBold" Foreground="#4ADE80" HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="#{0}">
                                                        <Binding Path="OrderId"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding TableLabel}" FontSize="16" Foreground="#94A3B8" HorizontalAlignment="Center" Visibility="{Binding TableLabel, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </DockPanel>

            <!-- Empty State overlays -->
            <TextBlock Grid.Column="0" Text="Nessun ordine in preparazione" FontSize="18" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0" Visibility="{Binding HasPreparingOrders, Converter={StaticResource InverseBoolToVisConverter}}"/>
            <TextBlock Grid.Column="2" Text="Nessun ordine pronto" FontSize="18" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0" Visibility="{Binding HasReadyOrders, Converter={StaticResource InverseBoolToVisConverter}}"/>
        </Grid>
    </DockPanel>
</UserControl>
