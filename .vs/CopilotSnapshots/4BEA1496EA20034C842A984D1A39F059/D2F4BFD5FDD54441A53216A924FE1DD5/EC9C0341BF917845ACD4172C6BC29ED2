<Window x:Class="Applicazione_OrdiniInterna.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Applicazione_OrdiniInterna.Views"
        Title="Bella Cucina — Gestione Ordini" Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,8">
                    <TextBlock Text="🍕 Bella Cucina" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Gestione Sagra" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Connection settings -->
                <StackPanel DockPanel.Dock="Top" Margin="16,8,16,4">
                    <TextBlock Text="Server" FontSize="10" Foreground="#94A3B8" Margin="4,0,0,4"/>
                    <TextBox x:Name="ServerUrlBox" Text="http://localhost:5225" Style="{StaticResource ModernTextBox}" FontSize="11" Foreground="#1F2937" Margin="0,0,0,4"/>
                    <TextBlock Text="API Key" FontSize="10" Foreground="#94A3B8" Margin="4,4,0,4"/>
                    <TextBox x:Name="ApiKeyBox" Text="1234" Style="{StaticResource ModernTextBox}" FontSize="11" Foreground="#1F2937" Margin="0,0,0,4"/>
                    <Button Content="Connetti" Click="ConnectClick" Style="{StaticResource BrandButton}" FontSize="11" Padding="8,6" Margin="0,4,0,0"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#334155" Margin="16,12"/>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="12,0">
                    <Button x:Name="NavKitchen" Content="🔥  Cucina" Click="NavKitchenClick" Style="{StaticResource SidebarButtonActive}" Margin="0,2"/>
                    <Button x:Name="NavDashboard" Content="📋  Dashboard" Click="NavDashboardClick" Style="{StaticResource SidebarButton}" Margin="0,2"/>
                    <Button x:Name="NavTables" Content="🪑  Tavoli &amp; QR" Click="NavTablesClick" Style="{StaticResource SidebarButton}" Margin="0,2"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,8,16,16" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Non connesso" FontSize="11" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <views:KitchenView x:Name="KitchenPanel" Visibility="Visible"/>
            <views:DashboardView x:Name="DashboardPanel" Visibility="Collapsed"/>
            <views:TablesView x:Name="TablesPanel" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
