<UserControl x:Class="Applicazione_OrdiniInterna.Views.KitchenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBg}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#0F172A" Padding="20,14">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="🔥 CUCINA" FontSize="22" FontWeight="Bold" Foreground="#22C55E"/>
                    <TextBlock x:Name="ClockText" Text="00:00:00" FontSize="18" FontWeight="SemiBold" Foreground="#9CA3AF" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#1E3A5F" CornerRadius="20" Padding="12,6" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="NUOVI " FontSize="12" FontWeight="SemiBold" Foreground="#60A5FA" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PaidCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#60A5FA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#3D2A00" CornerRadius="20" Padding="12,6" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PREP. " FontSize="12" FontWeight="SemiBold" Foreground="#FBBF24" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PrepCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#FBBF24" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0A3D1E" CornerRadius="20" Padding="12,6" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PRONTI " FontSize="12" FontWeight="SemiBold" Foreground="#22C55E" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ReadyCount" Text="0" FontSize="18" FontWeight="Bold" Foreground="#22C55E" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Orders Grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl x:Name="OrdersList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="340"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>