<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bella Cucina | Ordina Online</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'sans-serif'] },
          colors: {
            brand: { 50: '#fef7ee', 100: '#fdedd3', 500: '#f97316', 600: '#ea580c', 700: '#c2410c' }
          }
        }
      }
    }
  </script>
  <style>
    * { scrollbar-width: thin; scrollbar-color: #e5e7eb transparent; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .cart-drawer { transform: translateX(100%); transition: transform 0.3s ease-in-out; }
    .cart-drawer.open { transform: translateX(0); }
    .overlay { opacity: 0; visibility: hidden; transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out; }
    .overlay.open { opacity: 1; visibility: visible; }
    .category-btn.active { background-color: #f97316; color: white; }
    .add-btn:active { transform: scale(0.95); }
    @keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.2); } 100% { transform: scale(1); } }
    .pop { animation: pop 0.3s ease-in-out; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { animation: spin 0.8s linear infinite; border: 3px solid #e5e7eb; border-top-color: #f97316; border-radius: 50%; width: 2.5rem; height: 2.5rem; }
  </style>
</head>
<body class="font-sans bg-gray-50 min-h-screen">

  <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/80 backdrop-blur-lg border-b border-gray-100">
    <div class="max-w-2xl mx-auto px-4 py-4">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900">Bella Cucina</h1>
          <p id="table-label" class="text-sm text-gray-500">Menù</p>
        </div>
        <button onclick="openCart()" class="relative p-3 bg-brand-50 rounded-full hover:bg-brand-100 transition-colors">
          <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
          <span id="cart-count" class="absolute -top-1 -right-1 w-5 h-5 bg-brand-500 text-white text-xs font-bold rounded-full flex items-center justify-center hidden">0</span>
        </button>
      </div>
    </div>
  </header>

  <!-- Categories -->
  <nav class="sticky top-[73px] z-30 bg-white border-b border-gray-100">
    <div class="max-w-2xl mx-auto px-4 py-3">
      <div id="category-bar" class="flex gap-2 overflow-x-auto hide-scrollbar"></div>
    </div>
  </nav>

  <!-- Menu Items -->
  <main class="max-w-2xl mx-auto px-4 py-6">
    <div id="loading" class="flex flex-col items-center justify-center py-20">
      <div class="spinner"></div>
      <p class="mt-4 text-gray-500 text-sm">Caricamento menù...</p>
    </div>
    <div id="error-msg" class="hidden text-center py-20">
      <p class="text-red-500 font-medium">Errore nel caricamento dei prodotti.</p>
      <button onclick="loadProducts()" class="mt-4 px-6 py-2 bg-brand-500 text-white rounded-full text-sm font-medium hover:bg-brand-600 transition-colors">Riprova</button>
    </div>
    <div id="menu-grid" class="grid gap-4"></div>
  </main>

  <!-- Overlay -->
  <div id="overlay" class="overlay fixed inset-0 bg-black/50 z-50" onclick="closeCart()"></div>

  <!-- Cart Drawer -->
  <div id="cart-drawer" class="cart-drawer fixed right-0 top-0 h-full w-full max-w-md bg-white z-50 shadow-2xl flex flex-col">
    <div class="flex items-center justify-between p-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-gray-900">Il tuo ordine</h2>
      <button onclick="closeCart()" class="p-2 hover:bg-gray-100 rounded-full transition-colors">
        <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <div id="cart-items" class="flex-1 overflow-y-auto p-4 hidden"></div>
    <div id="cart-empty" class="flex-1 flex flex-col items-center justify-center p-4 text-center">
      <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-4">
        <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
      </div>
      <p class="text-gray-500 font-medium">Il carrello è vuoto</p>
      <p class="text-sm text-gray-400 mt-1">Aggiungi qualcosa di buono!</p>
    </div>
    <div id="cart-footer" class="border-t border-gray-100 p-4 space-y-4 hidden">
      <div class="flex items-center justify-between pt-2">
        <span class="text-lg font-semibold text-gray-900">Totale</span>
        <span id="total" class="text-lg font-bold text-brand-600">€0,00</span>
      </div>
      <button id="checkout-btn" onclick="checkout()" class="w-full py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-2xl transition-colors active:scale-[0.98]">
        Invia Ordine
      </button>
    </div>
  </div>

  <!-- Floating Cart Button -->
  <button id="floating-cart" onclick="openCart()" class="fixed bottom-6 right-6 z-40 p-4 bg-brand-500 text-white rounded-full shadow-lg shadow-brand-500/30 hover:bg-brand-600 transition-all hidden">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
    </svg>
    <span id="floating-cart-count" class="absolute -top-1 -right-1 w-6 h-6 bg-white text-brand-600 text-xs font-bold rounded-full flex items-center justify-center">0</span>
  </button>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-24 left-1/2 -translate-x-1/2 z-50 px-4 py-3 bg-gray-900 text-white text-sm font-medium rounded-full shadow-lg opacity-0 transition-opacity pointer-events-none">
    Aggiunto al carrello!
  </div>

  <script>
      const API_BASE = window.location.origin + "/api";

    // ── Leggi token tavolo da URL: ?t=abc123 ──
    const urlParams = new URLSearchParams(window.location.search);
    const tableToken = urlParams.get('t') || null;

    let tableName = null;
    let tableVerified = false;

    async function verifyTable() {
      if (!tableToken) return;
      try {
        const res = await fetch(`${API_BASE}/Tables/verify/${tableToken}`);
        if (res.ok) {
          const data = await res.json();
          tableName = data.name || `Tavolo ${data.number}`;
          tableVerified = true;
          document.getElementById('table-label').textContent = tableName;
        } else {
          document.getElementById('table-label').textContent = '⚠️ Tavolo non valido';
          document.getElementById('table-label').classList.add('text-red-500');
        }
      } catch (err) {
        console.error('Errore verifica tavolo:', err);
      }
    }

    // Mostra il tavolo nell'header
    if (tableToken) {
      document.getElementById('table-label').textContent = 'Verifica tavolo...';
      verifyTable();
    }

    let menuItems = [];
    let categories = [];
    let cart = [];
    let currentCategory = 'all';

    const categoryEmojis = {
      'pizza': '🍕', 'drinks': '🥤', 'bevande': '🥤', 'desserts': '🍰',
      'dolci': '🍰', 'antipasti': '🥗', 'primi': '🍝', 'secondi': '🥩',
      'contorni': '🥬', 'panini': '🥪', 'insalate': '🥗', 'birre': '🍺',
      'vini': '🍷', 'cocktail': '🍹',
    };

    function getEmoji(category) {
      return categoryEmojis[(category || '').toLowerCase().trim()] || '🍽️';
    }

    function formatPrice(price) {
      return '€' + price.toFixed(2).replace('.', ',');
    }

    function getProductImage(item) {
      const emoji = getEmoji(item.category || '');
      return `<div class="w-full h-full bg-brand-50 flex items-center justify-center text-4xl">${emoji}</div>`;
    }

    function escapeHtml(text) {
      const d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    // ── Carica prodotti ──
    async function loadProducts() {
      const loading = document.getElementById('loading');
      const errorMsg = document.getElementById('error-msg');
      const grid = document.getElementById('menu-grid');
      loading.classList.remove('hidden');
      errorMsg.classList.add('hidden');
      grid.innerHTML = '';

      try {
        const res = await fetch(`${API_BASE}/Products/GetProducts?disponibile=true`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        menuItems = await res.json();
        const cats = [...new Set(menuItems.map(p => (p.category || 'altro').trim()))];
        cats.sort();
        categories = cats;
        renderCategories();
        renderMenu();
        loading.classList.add('hidden');
      } catch (err) {
        console.error('Errore caricamento prodotti:', err);
        loading.classList.add('hidden');
        errorMsg.classList.remove('hidden');
      }
    }

    function renderCategories() {
      const bar = document.getElementById('category-bar');
      let html = `<button onclick="filterCategory('all', this)" class="category-btn active flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-700 transition-all">Tutti</button>`;
      categories.forEach(cat => {
        const emoji = getEmoji(cat);
        const label = cat.charAt(0).toUpperCase() + cat.slice(1);
        html += `<button onclick="filterCategory('${cat.replace(/'/g, "\\'")}', this)" class="category-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-700 transition-all">${emoji} ${label}</button>`;
      });
      bar.innerHTML = html;
    }

    function renderMenu() {
      const grid = document.getElementById('menu-grid');
      const filtered = currentCategory === 'all'
        ? menuItems
        : menuItems.filter(item => (item.category || '').toLowerCase().trim() === currentCategory.toLowerCase());

      if (filtered.length === 0) {
        grid.innerHTML = `<div class="text-center py-12 text-gray-400"><p>Nessun prodotto in questa categoria.</p></div>`;
        return;
      }

      grid.innerHTML = filtered.map(item => `
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
          <div class="flex">
            <div class="flex-1 p-4">
              <h3 class="font-semibold text-gray-900">${escapeHtml(item.name)}</h3>
              <p class="text-sm text-gray-500 mt-1 line-clamp-2">${escapeHtml(item.description || '')}</p>
              <div class="flex items-center justify-between mt-3">
                <span class="text-lg font-bold text-gray-900">${formatPrice(item.price)}</span>
                <button onclick="addToCart(${item.id})" class="add-btn px-4 py-2 bg-brand-500 hover:bg-brand-600 text-white text-sm font-medium rounded-full transition-colors">Aggiungi</button>
              </div>
            </div>
            <div class="w-28 h-28 flex-shrink-0">${getProductImage(item)}</div>
          </div>
        </div>
      `).join('');
    }

    function filterCategory(category, btn) {
      currentCategory = category;
      document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
      if (btn) btn.classList.add('active');
      renderMenu();
    }

    function addToCart(id) {
      const item = menuItems.find(i => i.id === id);
      if (!item) return;
      const cartItem = cart.find(i => i.id === id);
      if (cartItem) cartItem.quantity++;
      else cart.push({ ...item, quantity: 1 });
      updateCart();
      showToast();
    }

    function updateCart() {
      const count = cart.reduce((sum, item) => sum + item.quantity, 0);
      const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
      const cartCount = document.getElementById('cart-count');
      const floatingCartCount = document.getElementById('floating-cart-count');
      const floatingCart = document.getElementById('floating-cart');
      cartCount.textContent = count;
      floatingCartCount.textContent = count;
      if (count > 0) {
        cartCount.classList.remove('hidden');
        floatingCart.classList.remove('hidden');
        cartCount.classList.add('pop');
        setTimeout(() => cartCount.classList.remove('pop'), 300);
      } else {
        cartCount.classList.add('hidden');
        floatingCart.classList.add('hidden');
      }
      document.getElementById('total').textContent = formatPrice(total);
      const cartItemsEl = document.getElementById('cart-items');
      const cartEmpty = document.getElementById('cart-empty');
      const cartFooter = document.getElementById('cart-footer');
      if (cart.length === 0) {
        cartItemsEl.classList.add('hidden');
        cartEmpty.classList.remove('hidden');
        cartFooter.classList.add('hidden');
      } else {
        cartItemsEl.classList.remove('hidden');
        cartEmpty.classList.add('hidden');
        cartFooter.classList.remove('hidden');
        cartItemsEl.innerHTML = cart.map(item => `
          <div class="flex items-center gap-4 py-4 border-b border-gray-100 last:border-0">
            <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0">${getProductImage(item)}</div>
            <div class="flex-1 min-w-0">
              <h4 class="font-medium text-gray-900 truncate">${escapeHtml(item.name)}</h4>
              <p class="text-brand-600 font-semibold">${formatPrice(item.price * item.quantity)}</p>
            </div>
            <div class="flex items-center gap-2">
              <button onclick="updateQuantity(${item.id}, -1)" class="w-8 h-8 flex items-center justify-center bg-gray-100 hover:bg-gray-200 rounded-full transition-colors">
                <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path></svg>
              </button>
              <span class="w-8 text-center font-medium text-gray-900">${item.quantity}</span>
              <button onclick="updateQuantity(${item.id}, 1)" class="w-8 h-8 flex items-center justify-center bg-gray-100 hover:bg-gray-200 rounded-full transition-colors">
                <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </button>
            </div>
          </div>
        `).join('');
      }
    }

    function updateQuantity(id, change) {
      const cartItem = cart.find(i => i.id === id);
      if (cartItem) {
        cartItem.quantity += change;
        if (cartItem.quantity <= 0) cart = cart.filter(i => i.id !== id);
        updateCart();
      }
    }

    function openCart() {
      document.getElementById('cart-drawer').classList.add('open');
      document.getElementById('overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeCart() {
      document.getElementById('cart-drawer').classList.remove('open');
      document.getElementById('overlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message || 'Aggiunto al carrello!';
      toast.style.opacity = '1';
      setTimeout(() => { toast.style.opacity = '0'; }, 2000);
    }

    // ── Checkout con numero tavolo ──
    async function checkout() {
      if (cart.length === 0) return;
      const btn = document.getElementById('checkout-btn');
      btn.disabled = true;
      btn.textContent = 'Invio in corso...';

      const orderDto = {
        tableNumber: tableNumber,
        orderItems: cart.map(item => ({
          productId: item.id,
          quantity: item.quantity
        }))
      };

      try {
        // 1. Crea l'ordine (nasce in stato Pending)
        const res = await fetch(`${API_BASE}/Orders/createorder`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(orderDto)
        });
        if (!res.ok) {
          const errText = await res.text();
          throw new Error(errText || `HTTP ${res.status}`);
        }
        const order = await res.json();

        // 2. Conferma/Paga l'ordine così passa in stato Paid e la cucina lo vede!
        await fetch(`${API_BASE}/Orders/${order.id}/pay`, { 
          method: 'PATCH' 
        });

        cart = [];
        updateCart();
        closeCart();
        showToast(`✅ Ordine #${order.id} confermato! Totale: ${formatPrice(order.totalPrice ?? 0)}`);
      } catch (err) {
        console.error('Errore invio ordine:', err);
        alert('Errore nell\'invio dell\'ordine:\n' + err.message);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Invia Ordine';
      }
    }

    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeCart(); });

    loadProducts();
    updateCart();
  </script>
</body>
</html>