<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu Manager - Admin Ristorante</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#2d8a5e',
                        'primary-hover': '#246d4b',
                    }
                }
            }
        }
    </script>
    <script>
        let password = sessionStorage.getItem('admin-key');
        if (!password) {
            password = prompt("Inserisci password admin:");
            if (!password) {
                document.body.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100vh;font-size:1.5rem;color:#ef4444;">Accesso negato</div>';
                throw new Error('No password');
            }
            sessionStorage.setItem('admin-key', password);
        }
    </script>
    <style>
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .modal-backdrop {
            background-color: rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
  <div class="flex flex-col md:flex-row h-screen">
    <!-- Sidebar -->
    <aside class="w-full md:w-64 bg-white border-b md:border-r border-gray-200 flex flex-col">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center md:block">
        <h1 class="text-xl font-semibold text-gray-900">Menu Manager</h1>
        <p class="text-sm text-gray-500 mt-1">Admin Ristorante</p>
      </div>
      <nav class="flex-1 p-4">
        <ul class="space-y-1">
          <li>
            <a href="#" onclick="showSection('menu'); return false;" id="nav-menu" class="flex items-center gap-3 px-3 py-2 rounded-md bg-green-50 text-primary font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              Piatti del Menu
            </a>
          </li>
          <li>
            <a href="/kitchen.html" class="flex items-center gap-3 px-3 py-2 rounded-md text-gray-600 hover:bg-gray-100">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
              Cucina
            </a>
          </li>
          <li>
            <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-md text-gray-600 hover:bg-gray-100">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              Menù Clienti
            </a>
          </li>
          <li>
            <a href="#" onclick="showSection('tables'); return false;" id="nav-tables" class="flex items-center gap-3 px-3 py-2 rounded-md text-gray-600 hover:bg-gray-100">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
              Tavoli &amp; QR
            </a>
          </li>
        </ul>
      </nav>
      <div class="p-4 border-t border-gray-200">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-primary text-white flex items-center justify-center font-medium">A</div>
          <div>
            <p class="text-sm font-medium">Admin</p>
            <p class="text-xs text-gray-500">admin@ristorante.it</p>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <div class="p-8">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-xl md:text-2xl font-semibold text-gray-900">Piatti del Menu</h2>
                <p class="text-gray-500 mt-1 text-sm md:text-base">Gestisci i piatti del tuo ristorante</p>
              </div>
              <button onclick="openModal()" class="flex items-center gap-2 px-3 py-1.5 md:px-4 md:py-2 bg-primary text-white rounded-md hover:bg-primary-hover transition-colors text-sm md:text-base">
                <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                <span class="hidden md:inline">Aggiungi Piatto</span>
                <span class="inline md:hidden">Nuovo</span>
              </button>
            </div>

            <!-- Filters -->
            <div class="flex flex-col md:flex-row gap-4 mb-6">
              <div class="w-full md:flex-1 md:max-w-sm">
                <input type="text" id="searchInput" placeholder="Cerca piatti..." oninput="renderFiltered()" class="w-full px-4 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
              </div>
              <select id="categoryFilter" onchange="renderFiltered()" class="w-full md:w-auto px-4 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary bg-white">
            <option value="">Tutte le categorie</option>
          </select>
        </div>

        <!-- Table -->
        <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
          <table class="w-full min-w-[800px]">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Nome</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Descrizione</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Categoria</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Prezzo</th>
                <th class="text-center px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Disponibile</th>
                <th class="text-right px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Azioni</th>
              </tr>
            </thead>
            <tbody id="menuTableBody" class="divide-y divide-gray-200"></tbody>
          </table>
          <div id="emptyState" class="hidden p-12 text-center">
            <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            <p class="text-gray-500">Nessun piatto trovato</p>
          </div>
          <div id="loadingState" class="p-12 text-center">
            <div class="inline-block w-8 h-8 border-4 border-gray-200 border-t-primary rounded-full animate-spin"></div>
            <p class="text-gray-500 mt-4">Caricamento prodotti...</p>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Add/Edit Modal -->
  <div id="modal" class="fixed inset-0 z-50 hidden">
    <div class="modal-backdrop absolute inset-0" onclick="closeModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white rounded-lg shadow-xl">
      <div class="p-6 border-b border-gray-200">
        <h3 id="modalTitle" class="text-lg font-semibold">Aggiungi Piatto</h3>
        <p class="text-sm text-gray-500 mt-1">Inserisci i dettagli del piatto</p>
      </div>
      <form id="menuForm" onsubmit="saveItem(event)" class="p-6 space-y-4">
        <input type="hidden" id="itemId">
        <div>
          <label for="itemName" class="block text-sm font-medium text-gray-700 mb-1">Nome</label>
          <input type="text" id="itemName" required class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="Es. Spaghetti alla Carbonara">
        </div>
        <div>
          <label for="itemDescription" class="block text-sm font-medium text-gray-700 mb-1">Descrizione</label>
          <input type="text" id="itemDescription" class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="Es. Pasta con guanciale, uova e pecorino">
        </div>
        <div>
          <label for="itemPrice" class="block text-sm font-medium text-gray-700 mb-1">Prezzo (€)</label>
          <input type="number" id="itemPrice" step="0.01" min="0.01" required class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="12.50">
        </div>
        <div>
          <label for="itemCategory" class="block text-sm font-medium text-gray-700 mb-1">Categoria</label>
          <input type="text" id="itemCategory" required class="w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" placeholder="Es. Primi, Secondi, Bevande..." list="categorySuggestions">
          <datalist id="categorySuggestions"></datalist>
        </div>
        <div id="formError" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-md"></div>
        <div class="flex gap-3 pt-4">
          <button type="button" onclick="closeModal()" class="flex-1 px-4 py-2 border border-gray-200 rounded-md hover:bg-gray-50 transition-colors">Annulla</button>
          <button type="submit" id="saveBtn" class="flex-1 px-4 py-2 bg-primary text-white rounded-md hover:bg-primary-hover transition-colors">Salva</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteModal" class="fixed inset-0 z-50 hidden">
    <div class="modal-backdrop absolute inset-0" onclick="closeDeleteModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm bg-white rounded-lg shadow-xl p-6">
      <h3 class="text-lg font-semibold mb-2">Conferma eliminazione</h3>
      <p class="text-gray-500 mb-6">Sei sicuro di voler eliminare <strong id="deleteItemName"></strong>? Questa azione non può essere annullata.</p>
      <div class="flex gap-3">
        <button onclick="closeDeleteModal()" class="flex-1 px-4 py-2 border border-gray-200 rounded-md hover:bg-gray-50 transition-colors">Annulla</button>
        <button onclick="confirmDelete()" id="deleteBtn" class="flex-1 px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors">Elimina</button>
      </div>
    </div>
  </div>

  <script>
      const API_BASE = window.location.origin + "/api/Products";

    function handle401(res) {
      if (res.status === 401) {
        sessionStorage.removeItem('admin-key');
        alert('Password errata o sessione scaduta. Ricarica la pagina.');
        location.reload();
        return true;
      }
      return false;
    }

    let menuItems = [];
    let deleteItemId = null;

    const categoryColors = {
      'antipasti': 'bg-amber-100 text-amber-800',
      'primi': 'bg-blue-100 text-blue-800',
      'secondi': 'bg-red-100 text-red-800',
      'contorni': 'bg-green-100 text-green-800',
      'dolci': 'bg-pink-100 text-pink-800',
      'bevande': 'bg-purple-100 text-purple-800',
      'pizza': 'bg-orange-100 text-orange-800',
      'desserts': 'bg-pink-100 text-pink-800',
      'drinks': 'bg-cyan-100 text-cyan-800',
    };

    function getCategoryColor(cat) {
      return categoryColors[(cat || '').toLowerCase().trim()] || 'bg-gray-100 text-gray-800';
    }

    function escapeHtml(text) {
      const d = document.createElement('div');
      d.textContent = text;
      return d.innerHTML;
    }

    // ── FETCH prodotti dal backend ──
    async function loadProducts() {
      document.getElementById('loadingState').classList.remove('hidden');
      document.getElementById('emptyState').classList.add('hidden');
      document.getElementById('menuTableBody').innerHTML = '';

      try {
        const res = await fetch(`${API_BASE}/GetProducts`, {
            headers: { 'X-Api-Key': password }
        });
        if (handle401(res)) return;
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        menuItems = await res.json();
        buildCategoryFilter();
        renderFiltered();
      } catch (err) {
        console.error('Errore caricamento:', err);
        document.getElementById('menuTableBody').innerHTML = '';
        document.getElementById('emptyState').classList.remove('hidden');
        document.getElementById('emptyState').querySelector('p').textContent = 'Errore nel caricamento dei prodotti';
      } finally {
        document.getElementById('loadingState').classList.add('hidden');
      }
    }

    // ── Costruisci filtro categorie dinamico ──
    function buildCategoryFilter() {
      const cats = [...new Set(menuItems.map(p => (p.category || '').trim()).filter(Boolean))].sort();
      const select = document.getElementById('categoryFilter');
      const current = select.value;

      // Mantieni solo la prima opzione "Tutte"
      select.innerHTML = '<option value="">Tutte le categorie</option>';
      cats.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c.charAt(0).toUpperCase() + c.slice(1);
        select.appendChild(opt);
      });
      select.value = current;

      // Aggiorna anche i suggerimenti nel form
      const datalist = document.getElementById('categorySuggestions');
      datalist.innerHTML = cats.map(c => `<option value="${escapeHtml(c)}">`).join('');
    }

    // ── Render tabella filtrata ──
    function renderFiltered() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const category = document.getElementById('categoryFilter').value;

      const filtered = menuItems.filter(item => {
        const matchSearch = (item.name || '').toLowerCase().includes(search)
          || (item.description || '').toLowerCase().includes(search);
        const matchCat = !category || (item.category || '').toLowerCase() === category.toLowerCase();
        return matchSearch && matchCat;
      });

      renderTable(filtered);
    }

    function renderTable(items) {
      const tbody = document.getElementById('menuTableBody');
      const emptyState = document.getElementById('emptyState');

      if (items.length === 0) {
        tbody.innerHTML = '';
        emptyState.classList.remove('hidden');
        emptyState.querySelector('p').textContent = 'Nessun piatto trovato';
        return;
      }

      emptyState.classList.add('hidden');
      tbody.innerHTML = items.map(item => `
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4">
            <span class="font-medium text-gray-900">${escapeHtml(item.name)}</span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate">
            ${escapeHtml(item.description || '—')}
          </td>
          <td class="px-6 py-4">
            <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium ${getCategoryColor(item.category)}">
              ${escapeHtml(item.category || 'Altro')}
            </span>
          </td>
          <td class="px-6 py-4 text-gray-900 font-medium">
            &euro;${item.price.toFixed(2)}
          </td>
          <td class="px-6 py-4 text-center">
            <button onclick="toggleAvailability(${item.id})" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium transition-colors ${item.isAvailable
              ? 'bg-green-100 text-green-800 hover:bg-green-200'
              : 'bg-red-100 text-red-800 hover:bg-red-200'}">
              ${item.isAvailable ? '✓ Disponibile' : '✗ Non disponibile'}
            </button>
          </td>
          <td class="px-6 py-4 text-right">
            <button onclick="editItem(${item.id})" class="text-gray-500 hover:text-primary p-1 rounded" title="Modifica">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
            <button onclick="deleteItem(${item.id})" class="text-gray-500 hover:text-red-600 p-1 rounded ml-1" title="Elimina">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </td>
        </tr>
      `).join('');
    }

    // ── Toggle disponibilità ──
    async function toggleAvailability(id) {
      try {
        const res = await fetch(`${API_BASE}/${id}/availability`, { method: 'PATCH', headers: { 'X-Api-Key': password } });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const updated = await res.json();
        // Aggiorna localmente
        const idx = menuItems.findIndex(i => i.id === id);
        if (idx !== -1) menuItems[idx].isAvailable = updated.isAvailable;
        renderFiltered();
      } catch (err) {
        console.error('Errore toggle:', err);
        alert('Errore nel cambio disponibilità: ' + err.message);
      }
    }

    // ── Modal Aggiungi/Modifica ──
    function openModal(item = null) {
      const form = document.getElementById('menuForm');
      document.getElementById('formError').classList.add('hidden');

      if (item) {
        document.getElementById('modalTitle').textContent = 'Modifica Piatto';
        document.getElementById('itemId').value = item.id;
        document.getElementById('itemName').value = item.name || '';
        document.getElementById('itemDescription').value = item.description || '';
        document.getElementById('itemPrice').value = item.price;
        document.getElementById('itemCategory').value = item.category || '';
      } else {
        document.getElementById('modalTitle').textContent = 'Aggiungi Piatto';
        form.reset();
        document.getElementById('itemId').value = '';
      }

      document.getElementById('modal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('modal').classList.add('hidden');
    }

    function editItem(id) {
      const item = menuItems.find(i => i.id === id);
      if (item) openModal(item);
    }

    // ── Salva (POST nuovo / PUT modifica) ──
    async function saveItem(event) {
      event.preventDefault();
      const btn = document.getElementById('saveBtn');
      const errorEl = document.getElementById('formError');
      errorEl.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = 'Salvataggio...';

      const id = document.getElementById('itemId').value;
      const dto = {
        name: document.getElementById('itemName').value.trim(),
        price: parseFloat(document.getElementById('itemPrice').value),
        category: document.getElementById('itemCategory').value.trim(),
        description: document.getElementById('itemDescription').value.trim() || null
      };

      try {
        let res;
        if (id) {
          // PUT /api/Products?id=X
          res = await fetch(`${API_BASE}?id=${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'X-Api-Key': password },
            body: JSON.stringify(dto)
          });
        } else {
          // POST /api/Products
          res = await fetch(API_BASE, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Api-Key': password },
            body: JSON.stringify(dto)
          });
        }

        if (!res.ok) {
          const errText = await res.text().catch(() => '');
          throw new Error(errText || `HTTP ${res.status}`);
        }

        closeModal();
        await loadProducts();
      } catch (err) {
        console.error('Errore salvataggio:', err);
        errorEl.textContent = err.message || 'Errore nel salvataggio';
        errorEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Salva';
      }
    }

    // ── Elimina prodotto ──
    function deleteItem(id) {
      deleteItemId = id;
      const item = menuItems.find(i => i.id === id);
      document.getElementById('deleteItemName').textContent = item?.name || `#${id}`;
      document.getElementById('deleteModal').classList.remove('hidden');
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.add('hidden');
      deleteItemId = null;
    }

    async function confirmDelete() {
      if (!deleteItemId) return;
      const btn = document.getElementById('deleteBtn');
      btn.disabled = true;
      btn.textContent = 'Eliminazione...';

      try {
        const res = await fetch(`${API_BASE}/${deleteItemId}`, { method: 'DELETE', headers: { 'X-Api-Key': password } });
        if (!res.ok) {
          const errText = await res.text().catch(() => '');
          throw new Error(errText || `HTTP ${res.status}`);
        }
        closeDeleteModal();
        await loadProducts();
      } catch (err) {
        console.error('Errore eliminazione:', err);
        alert('Errore: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Elimina';
      }
    }

    // ── Avvio ──
    loadProducts();
  </script>
</body>
</html>