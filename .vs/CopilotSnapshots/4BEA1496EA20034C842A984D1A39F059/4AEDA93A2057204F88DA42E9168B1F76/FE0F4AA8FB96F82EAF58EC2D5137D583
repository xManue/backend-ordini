using System.Diagnostics;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;
using System.Windows.Media.Imaging;
using Applicazione_OrdiniInterna.Models;
using Applicazione_OrdiniInterna.Services;

namespace Applicazione_OrdiniInterna.Views;

public partial class TablesView : UserControl
{
    private ApiService? _api;
    private List<TableDto> _tables = [];

    public TablesView() => InitializeComponent();

    public async void Initialize(ApiService api)
    {
        _api = api;
        await LoadTables();
    }

    private async Task LoadTables()
    {
        if (_api == null) return;
        try
        {
            _tables = await _api.GetTablesAsync();
            RenderTables();
        }
        catch (Exception ex) { MessageBox.Show($"Errore:\n{ex.Message}"); }
    }

    private void RenderTables()
    {
        TablesList.Items.Clear();
        foreach (var t in _tables.OrderBy(x => x.Number))
        {
            var borderColor = t.IsActive ? Color.FromRgb(187, 247, 208) : Color.FromRgb(229, 231, 235);
            var card = new Border
            {
                Background = Brushes.White,
                BorderBrush = new SolidColorBrush(borderColor),
                BorderThickness = new Thickness(2),
                CornerRadius = new CornerRadius(12),
                Padding = new Thickness(16),
                Margin = new Thickness(0, 0, 12, 12),
                Opacity = t.IsActive ? 1 : 0.6
            };

            var stack = new StackPanel();

            // Header
            var header = new DockPanel { Margin = new Thickness(0, 0, 0, 12) };
            var left = new StackPanel();
            left.Children.Add(new TextBlock { Text = $"#{t.Number}", FontSize = 24, FontWeight = FontWeights.Bold });
            if (!string.IsNullOrEmpty(t.Name))
                left.Children.Add(new TextBlock { Text = t.Name, FontSize = 12, Foreground = (SolidColorBrush)FindResource("TextSecondary") });
            header.Children.Add(left);

            var statusBorder = new Border
            {
                Background = t.IsActive ? new SolidColorBrush(Color.FromRgb(220, 252, 231)) : new SolidColorBrush(Color.FromRgb(254, 226, 226)),
                CornerRadius = new CornerRadius(10),
                Padding = new Thickness(8, 3, 8, 3),
                HorizontalAlignment = HorizontalAlignment.Right,
                VerticalAlignment = VerticalAlignment.Top
            };
            statusBorder.Child = new TextBlock
            {
                Text = t.IsActive ? "✓ Attivo" : "✗ Disattivato",
                FontSize = 11, FontWeight = FontWeights.SemiBold,
                Foreground = t.IsActive ? new SolidColorBrush(Color.FromRgb(22, 101, 52)) : new SolidColorBrush(Color.FromRgb(153, 27, 27))
            };
            DockPanel.SetDock(statusBorder, Dock.Right);
            header.Children.Add(statusBorder);
            stack.Children.Add(header);

            // Buttons row 1
            var row1 = new StackPanel { Orientation = Orientation.Horizontal, Margin = new Thickness(0, 0, 0, 6) };
            var qrBtn = new Button { Content = "📱 QR Code", Style = (Style)FindResource("SecondaryButton"), FontSize = 11, Padding = new Thickness(10, 6, 10, 6), Margin = new Thickness(0, 0, 6, 0) };
            var tableId = t.Id;
            var token = t.Token;
            qrBtn.Click += (_, _) => ShowQr(t);
            row1.Children.Add(qrBtn);

            var toggleBtn = new Button
            {
                Content = t.IsActive ? "Disattiva" : "Attiva",
                Style = t.IsActive ? (Style)FindResource("DangerButton") : (Style)FindResource("GreenButton"),
                FontSize = 11, Padding = new Thickness(10, 6, 10, 6), Margin = new Thickness(0, 0, 6, 0)
            };
            toggleBtn.Click += async (_, _) => { try { await _api!.ToggleTableActiveAsync(tableId); await LoadTables(); } catch (Exception ex) { MessageBox.Show(ex.Message); } };
            row1.Children.Add(toggleBtn);
            stack.Children.Add(row1);

            // Buttons row 2
            var row2 = new StackPanel { Orientation = Orientation.Horizontal };
            var regenBtn = new Button { Content = "🔄 Rigenera QR", Style = (Style)FindResource("SecondaryButton"), FontSize = 11, Padding = new Thickness(10, 6, 10, 6), Margin = new Thickness(0, 0, 6, 0) };
            regenBtn.Click += async (_, _) =>
            {
                if (MessageBox.Show("Rigenerare il token? Il vecchio QR smetterà di funzionare.", "Conferma", MessageBoxButton.YesNo) == MessageBoxResult.Yes)
                {
                    try { await _api!.RegenerateTableTokenAsync(tableId); await LoadTables(); } catch (Exception ex) { MessageBox.Show(ex.Message); }
                }
            };
            row2.Children.Add(regenBtn);

            var delBtn = new Button { Content = "🗑️ Elimina", Style = (Style)FindResource("DangerButton"), FontSize = 11, Padding = new Thickness(10, 6, 10, 6) };
            delBtn.Click += async (_, _) =>
            {
                if (MessageBox.Show($"Eliminare Tavolo {t.Number}?", "Conferma", MessageBoxButton.YesNo) == MessageBoxResult.Yes)
                {
                    try { await _api!.DeleteTableAsync(tableId); await LoadTables(); } catch (Exception ex) { MessageBox.Show(ex.Message); }
                }
            };
            row2.Children.Add(delBtn);
            stack.Children.Add(row2);

            card.Child = stack;
            TablesList.Items.Add(card);
        }

        if (!_tables.Any())
        {
            TablesList.Items.Add(new TextBlock
            {
                Text = "Nessun tavolo configurato", FontSize = 14,
                Foreground = (SolidColorBrush)FindResource("TextSecondary"),
                HorizontalAlignment = HorizontalAlignment.Center, Margin = new Thickness(0, 40, 0, 0)
            });
        }
    }

    private void ShowQr(TableDto table)
    {
        var url = _api!.GetTableMenuUrl(table.Token);
        var qrUrl = _api.GetQrCodeUrl(table.Token);

        var dlg = new Window
        {
            Title = $"QR — {table.Name ?? $"Tavolo {table.Number}"}",
            Width = 400, Height = 460,
            WindowStartupLocation = WindowStartupLocation.CenterOwner,
            Owner = Window.GetWindow(this),
            ResizeMode = ResizeMode.NoResize,
            Background = Brushes.White
        };

        var stack = new StackPanel { Margin = new Thickness(24), HorizontalAlignment = HorizontalAlignment.Center };
        stack.Children.Add(new TextBlock { Text = $"QR — {table.Name ?? $"Tavolo {table.Number}"}", FontSize = 18, FontWeight = FontWeights.SemiBold, HorizontalAlignment = HorizontalAlignment.Center });

        var img = new Image { Width = 250, Height = 250, Margin = new Thickness(0, 16, 0, 16) };
        try { img.Source = new BitmapImage(new Uri(qrUrl)); } catch { }
        stack.Children.Add(img);

        stack.Children.Add(new TextBlock { Text = "Scansiona per aprire il menù", FontSize = 12, Foreground = Brushes.Gray, HorizontalAlignment = HorizontalAlignment.Center });

        var urlBox = new TextBox { Text = url, IsReadOnly = true, FontSize = 11, TextAlignment = TextAlignment.Center, Margin = new Thickness(0, 8, 0, 12), Padding = new Thickness(6) };
        stack.Children.Add(urlBox);

        var copyBtn = new Button { Content = "📋 Copia Link", Style = (Style)FindResource("BrandButton") };
        copyBtn.Click += (_, _) => { Clipboard.SetText(url); MessageBox.Show("Link copiato!"); };
        stack.Children.Add(copyBtn);

        dlg.Content = stack;
        dlg.ShowDialog();
    }

    private void AddTableClick(object sender, RoutedEventArgs e)
    {
        var dlg = new Dialogs.TableDialog { Owner = Window.GetWindow(this) };
        if (dlg.ShowDialog() == true)
        {
            _ = Task.Run(async () =>
            {
                try
                {
                    await _api!.CreateTableAsync(dlg.TableNumber, dlg.TableName);
                    await Dispatcher.InvokeAsync(async () => await LoadTables());
                }
                catch (Exception ex) { Dispatcher.Invoke(() => MessageBox.Show(ex.Message)); }
            });
        }
    }
}