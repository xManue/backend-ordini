<UserControl x:Class="Applicazione_OrdiniInterna.Views.TablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PageBg}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="24,16" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Gestione Tavoli" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Crea tavoli, genera QR code e gestisci gli accessi" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="➕ Aggiungi Tavolo" Click="AddTableClick" Style="{StaticResource BrandButton}" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Tables Grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TablesList" Margin="24,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="320"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>