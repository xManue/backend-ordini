<UserControl x:Class="Applicazione_OrdiniInterna.Views.CassaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Applicazione_OrdiniInterna.ViewModels"
             Background="{StaticResource PageBg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Product Grid -->
        <DockPanel Grid.Column="0">
            <!-- Header + Filters -->
            <Border DockPanel.Dock="Top" Padding="20,14" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="🛒 CASSA" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Width="200" Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="150" FontSize="13" Padding="8,6"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Category Quick Filters -->
            <Border DockPanel.Dock="Top" Padding="16,8" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Command="{Binding DataContext.FilterCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="4,2" Padding="12,6" FontSize="12" FontWeight="SemiBold" Background="#F3F4F6" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="{StaticResource BrandLightBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Product Grid -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="6" Cursor="Hand" BorderThickness="0" Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="card" Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16" Width="180" MinHeight="120">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandBrush}" Margin="0,8,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="€{0:F2}">
                                                            <Binding Path="Price"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource BrandBrush}"/>
                                                <Setter TargetName="card" Property="Background" Value="{StaticResource BrandLightBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- RIGHT: Cart Sidebar -->
        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <DockPanel>
                <!-- Cart Header -->
                <Border DockPanel.Dock="Top" Padding="20,16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="🧾 Ordine" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" DockPanel.Dock="Left"/>
                        <Button Content="Svuota" Command="{Binding ClearCartCommand}" Style="{StaticResource SecondaryButton}" FontSize="11" Padding="10,5" DockPanel.Dock="Right"/>
                    </DockPanel>
                </Border>

                <!-- Cart Footer (Total + Confirm) -->
                <Border DockPanel.Dock="Bottom" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- Order confirmed banner -->
                        <Border Background="#DCFCE7" CornerRadius="8" Padding="12,8" Margin="0,0,0,8" Visibility="{Binding OrderConfirmed, Converter={StaticResource BoolToVisConverter}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="✅ Ordine Confermato!" FontSize="14" FontWeight="Bold" Foreground="#166534" HorizontalAlignment="Center"/>
                                <TextBlock FontSize="20" FontWeight="ExtraBold" Foreground="#166534" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="#{0}">
                                            <Binding Path="LastOrderId"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Totale" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                            <TextBlock FontSize="22" FontWeight="ExtraBold" Foreground="{StaticResource BrandBrush}" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="€{0:F2}">
                                        <Binding Path="CartTotal"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DockPanel>
                        <Button Content="✅ Conferma Ordine" Command="{Binding ConfirmOrderCommand}" Style="{StaticResource GreenButton}" FontSize="16" Padding="16,14" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Cart Items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Cart}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F9FAFB" CornerRadius="10" Padding="12,10" Margin="4,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Product.Name}" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="€{0:F2}">
                                                        <Binding Path="Total"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Quantity Controls -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                            <Button Content="−" Command="{Binding DataContext.DecrementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="32" Height="32" FontSize="16" FontWeight="Bold" Background="#F3F4F6" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Width="32" Height="32">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#E5E7EB"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding Quantity}" FontSize="15" FontWeight="Bold" Width="30" TextAlignment="Center" VerticalAlignment="Center"/>
                                            <Button Content="+" Command="{Binding DataContext.IncrementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="32" Height="32" FontSize="16" FontWeight="Bold" Background="#F3F4F6" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Width="32" Height="32">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="#E5E7EB"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>

                                        <!-- Remove -->
                                        <Button Grid.Column="2" Content="✕" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" FontSize="12" Foreground="#EF4444" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Padding="6,4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
